# Public environment tag: development / staging / production
VITE_APP_ENV="development"

# Public site URL for self-referential links and callback construction.
VITE_APP_URL="https://wecom-dev.callfay.cn"

# API base URL used by the frontend at runtime.
VITE_API_BASE_URL="https://wecom-dev.callfay.cn"

# Request timeout in milliseconds.
VITE_API_TIMEOUT_MS="15000"
